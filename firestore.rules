/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model.
 * All user-generated data is stored within a top-level `/users/{userId}` collection,
 * making authorization checks simple, fast, and scalable. Access is restricted
 * to the authenticated user who owns the data tree.
 *
 * Data Structure: The data is organized hierarchically. A root `/users`
 * collection holds individual user profile documents. Each user document
 * can contain subcollections for `devices`, and each device can further
 * contain subcollections for `deviceSettings` and `captures`.
 *
 * Key Security Decisions:
 * - User Isolation: All data is nested under `/users/{userId}`, and rules
 *   primarily check if `request.auth.uid == userId`. This path-based security
 *   completely isolates one user's data from another.
 * - No Public Listing: It is not possible to list all users in the system.
 * - Secure by Default: Any path not explicitly matched is denied access. There
 *   are no public collections.
 *
 * Denormalization for Authorization: To ensure performant and simple rules,
 * ownership information is denormalized. For example, a `Device` document
 * under `/users/{userId}/devices/{deviceId}` contains a `userId` field. This
 * reinforces the ownership link and ensures relational integrity without
 * needing costly `get()` calls to parent documents.
 *
 * Structural Segregation: Each collection has a uniform security posture (all
 * documents are owned by the user in the path). This avoids complex conditional
 * logic within a single collection and makes list operations (`queries`)
 * inherently secure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the cornerstone of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A robust check for update/delete operations, ensuring the user is the
     * owner AND the document already exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates required relational fields on UserProfile creation.
     */
    function hasValidUserProfileDataOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the user ID on UserProfile update.
     */
    function hasValidUserProfileDataOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates required relational fields on Device creation.
     */
    function hasValidDeviceDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * Enforces immutability of the owner ID on Device update.
     */
    function hasValidDeviceDataOnUpdate() {
      return request.resource.data.userId == resource.data.id;
    }

    /**
     * Validates required relational fields on DeviceSettings creation.
     */
    function hasValidDeviceSettingsDataOnCreate(deviceId) {
      return request.resource.data.deviceId == deviceId;
    }

    /**
     * Enforces immutability of the device ID on DeviceSettings update.
     */
    function hasValidDeviceSettingsDataOnUpdate() {
      return request.resource.data.deviceId == resource.data.deviceId;
    }

    /**
     * Validates required relational fields on Capture creation.
     */
    function hasValidCaptureDataOnCreate(userId, deviceId) {
      return request.resource.data.userId == userId && request.resource.data.deviceId == deviceId;
    }

    /**
     * Enforces immutability of owner and device IDs on Capture update.
     */
    function hasValidCaptureDataOnUpdate() {
      return request.resource.data.userId == resource.data.id && request.resource.data.deviceId == resource.data.deviceId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Secures a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user creates their own profile document, where the document ID matches their auth UID.
     * @deny (get) An authenticated user attempts to read another user's profile document.
     * @principle Restricts access to a user's own root document and validates self-referential ID on create.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidUserProfileDataOnCreate(userId);
      allow update: if isExistingOwner(userId) && hasValidUserProfileDataOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the devices owned by a user.
     * @path /users/{userId}/devices/{deviceId}
     * @allow (create) The user with auth UID `{userId}` creates a new device document for themselves.
     * @deny (update) A different user attempts to modify a device document they do not own.
     * @principle Enforces strict ownership for all operations on a user's private subcollection.
     */
    match /users/{userId}/devices/{deviceId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidDeviceDataOnCreate(userId);
      allow update: if isExistingOwner(userId) && hasValidDeviceDataOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures settings specific to a user's device.
     * @path /users/{userId}/devices/{deviceId}/deviceSettings/{settingsId}
     * @allow (get) The user with auth UID `{userId}` reads the settings for one of their devices.
     * @deny (create) An unauthenticated user attempts to create a settings document.
     * @principle Restricts access to deeply nested data based on the top-level user ID in the path.
     */
    match /users/{userId}/devices/{deviceId}/deviceSettings/{settingsId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidDeviceSettingsDataOnCreate(deviceId);
      allow update: if isExistingOwner(userId) && hasValidDeviceSettingsDataOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures image capture records for a specific device owned by a user.
     * @path /users/{userId}/devices/{deviceId}/captures/{captureId}
     * @allow (delete) The user with auth UID `{userId}` deletes a capture record from one of their devices.
     * @deny (list) A different user attempts to list captures for a device they do not own.
     * @principle Validates relational integrity to both the user and device on creation, ensuring data consistency.
     */
    match /users/{userId}/devices/{deviceId}/captures/{captureId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidCaptureDataOnCreate(userId, deviceId);
      allow update: if isExistingOwner(userId) && hasValidCaptureDataOnUpdate();
      allow delete: if isExistingOwner(userId);
    }
  }
}