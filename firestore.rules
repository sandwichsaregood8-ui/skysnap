/**
 * This ruleset enforces a strict user-ownership security model for the SkySnap application.
 * All user-generated data, such as devices, settings, and image captures, is
 * stored within a hierarchical structure under that user's unique ID.
 *
 * Core Philosophy:
 * Access to any document is granted only to the authenticated user who owns that
 * data tree. This is primarily achieved by comparing the requester's authentication
 * UID (`request.auth.uid`) with the `{userId}` wildcard in the document path.
 *
 * Data Structure:
 * The Firestore database is organized hierarchically, starting with the `users`
 * collection. All other data is nested within a specific user's document:
 *   - /users/{userId} - (UserProfile)
 *   - /users/{userId}/devices/{deviceId} - (Device)
 *   - /users/{userId}/devices/{deviceId}/settings/config - (DeviceSetting)
 *   - /users/{userId}/devices/{deviceId}/captures/{captureId} - (Capture)
 *
 * Key Security Decisions:
 * - Strict Ownership: A user can only read or write data located under their
 *   own `/users/{userId}` path. There is no concept of shared or public data.
 * - No User Listing: It is not possible for any user, authenticated or not,
 *   to list all documents in the top-level `users` collection.
 * - Authorization Independence: To ensure rules are fast and simple, critical
 *   ownership information (like `userId` and `deviceId`) is denormalized
 *   (copied) onto child documents. This avoids slow and costly `get()` calls
 *   in security rules, ensuring that authorization can be determined from the
 *   document's path and its own data.
 * - Singleton Configuration: Device settings are stored as a singleton document
 *   named 'config' within a 'settings' subcollection to enforce a 1:1 relationship
 *   between a device and its configuration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * On create, validates that the new UserProfile document's 'id' field
     * matches the authenticated user's UID.
     */
    function isCreatingOwnProfile(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * On update, ensures the 'id' field of a UserProfile is immutable.
     */
    function isUpdatingOwnProfile() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * On create, validates that a new sub-document contains a 'userId' field
     * that matches the user from the path.
     */
    function isCreatingChildDoc(userId) {
      return request.resource.data.userId == userId;
    }
    
    /**
     * On update, ensures the 'userId' field of a sub-document is immutable.
     */
    function isUpdatingChildDoc() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    /**
     * On create, validates that a new Capture or Setting contains a 'deviceId'
     * field that matches the device from the path.
     */
    function isCreatingGrandchildDoc(deviceId) {
      return request.resource.data.deviceId == deviceId;
    }
    
    /**
     * On update, ensures the 'deviceId' field of a Capture or Setting is immutable.
     */
    function isUpdatingGrandchildDoc() {
      return request.resource.data.deviceId == resource.data.deviceId;
    }

    /**
     * Validates that the settings document being accessed is the singleton 'config'.
     */
    function isConfigDocument(settingId) {
      return settingId == 'config';
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny (get) An authenticated user ('user-abc') cannot read the profile of another user ('user-xyz').
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnProfile(userId);
      allow update: if isExistingOwner(userId) && isUpdatingOwnProfile();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages access to the devices owned by a user.
       * @path /users/{userId}/devices/{deviceId}
       * @allow (list) An authenticated user ('user-abc') can list all devices under their own path.
       * @deny (create) An authenticated user ('user-abc') cannot create a device under another user's path ('user-xyz').
       * @principle Enforces document ownership for all operations and validates relational integrity on create/update.
       */
      match /devices/{deviceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isCreatingChildDoc(userId);
        allow update: if isExistingOwner(userId) && isUpdatingChildDoc();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Secures the singleton configuration document for a specific device.
         * @path /users/{userId}/devices/{deviceId}/settings/{settingId}
         * @allow (get) An authenticated user ('user-abc') can get the 'config' document for their own device.
         * @deny (create) A user cannot create a settings document with an ID other than 'config'.
         * @deny (list) Listing the 'settings' collection is disallowed as it only contains one document.
         * @principle Enforces a 1:1 relationship via a singleton document pattern and maintains ownership from the parent.
         */
        match /settings/{settingId} {
          allow get: if isOwner(userId) && isConfigDocument(settingId);
          allow list: if false;
          allow create: if isOwner(userId) && isConfigDocument(settingId) && isCreatingChildDoc(userId) && isCreatingGrandchildDoc(deviceId);
          allow update: if isExistingOwner(userId) && isConfigDocument(settingId) && isUpdatingChildDoc() && isUpdatingGrandchildDoc();
          allow delete: if isExistingOwner(userId) && isConfigDocument(settingId);
        }

        /**
         * @description Controls access to image capture metadata for a specific device.
         * @path /users/{userId}/devices/{deviceId}/captures/{captureId}
         * @allow (create) An authenticated user can create a new capture record for one of their devices.
         * @deny (update) A user cannot change the `userId` or `deviceId` fields on an existing capture.
         * @principle Enforces strict ownership and ensures relational fields (`userId`, `deviceId`) are immutable.
         */
        match /captures/{captureId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isCreatingChildDoc(userId) && isCreatingGrandchildDoc(deviceId);
          allow update: if isExistingOwner(userId) && isUpdatingChildDoc() && isUpdatingGrandchildDoc();
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}